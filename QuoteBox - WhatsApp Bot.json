    {
      "parameters": {
        "jsCode": "const parsed = $('Code in JavaScript').first().json;\nconst allQuotes = $input.all().map(item => item.json);\n\nconst matches = allQuotes.filter(q => \n  q.autor && q.autor.toLowerCase().includes(parsed.author.toLowerCase())\n);\n\nlet responseText = '';\nlet needsLogging = false;\n\nif (matches.length === 0) {\n  responseText = `No tengo frases de \"${parsed.author}\" por ahora.`;\n  needsLogging = true;\n} else if (parsed.intent === 'count') {\n  responseText = `Tengo ${matches.length} frase(s) de ${matches[0].autor}.`;\n} else if (parsed.intent === 'list') {\n  responseText = matches.map(m => `\"${m.texto}\"`).join('\\n\\n');\n} else {\n  responseText = `Encontré ${matches.length} frase(s) de ${matches[0].autor}. Preguntame \"cuántas hay\" o \"cuáles son\".`;\n}\n\nreturn [{ json: { responseText, found: matches.length > 0, needsLogging, author: parsed.author } }];\n"
      },
