    {
      "parameters": {
        "jsCode": "const message = $json.body.Body.toLowerCase().trim().replace(/[¿?]/g, '');\nconst from = $json.body.From;\n\nlet intent = 'unknown';\n\nif (message.includes('cuántas') || message.includes('cuantas')) {\n  intent = 'count';\n} else if (message.includes('cuáles') || message.includes('cuales')) {\n  intent = 'list';\n}\n\n// Extraer autor: lo que viene después de \"de\"\nlet author = '';\nconst match = message.match(/\\bde\\s+(.+)/);\nif (match) {\n  author = match[1].trim();\n  // Quitar palabras finales irrelevantes como \"por favor\"\n  author = author.replace(/\\b(por favor|porfa)\\b/g, '').trim();\n}\n\nreturn [{ json: { intent, author, from, originalMessage: message } }];"
      },
