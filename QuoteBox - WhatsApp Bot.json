    {
      "parameters": {
        "jsCode": "const buildResponse = $('Build Response').first().json;\nconst author = buildResponse.author;\n\nconst existing = $input.all().map(item => item.json).filter(row => row.autor_consultado);\n\nconst found = existing.find(row => row.autor_consultado.toLowerCase() === author.toLowerCase());\n\nconst now = new Date().toISOString();\n\nif (found) {\n  // Ya existe, incrementamos el contador\n  return [{\n    json: {\n      action: 'update',\n      row_number: found.row_number,\n      autor_consultado: author,\n      veces_pedido: parseInt(found.veces_pedido) + 1,\n      primera_consulta: found.primera_consulta,\n      ultima_consulta: now,\n      escalado: found.escalado || 'false'\n    }\n  }];\n} else {\n  // Primera vez\n  return [{\n    json: {\n      action: 'insert',\n      autor_consultado: author,\n      veces_pedido: 1,\n      primera_consulta: now,\n      ultima_consulta: now,\n      escalado: 'false'\n    }\n  }];\n}"
      },
