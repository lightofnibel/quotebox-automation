    {
      "parameters": {
        "jsCode": "const newQuotes = $('filtrar tags').all().map(item => item.json);\n\nconst existing = $input.all().map(item => item.json).filter(row => row.texto);\n\nconst existingKeys = new Set(\n  existing.map(row => `${row.texto}|||${row.autor}`)\n);\n\nconst newOnes = newQuotes.filter(q => {\n  const key = `${q.text}|||${q.author}`;\n  return !existingKeys.has(key);\n});\n\nreturn newOnes.map(q => ({ json: q }));"
      },
