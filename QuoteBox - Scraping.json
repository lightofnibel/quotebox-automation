    {
      "parameters": {
        "jsCode": "const allQuotes = [];\n\nfor (const item of $input.all()) {\n  for (const quote of item.json.quotes) {\n    allQuotes.push({ json: quote });\n  }\n}\n\nreturn allQuotes;"
      },
