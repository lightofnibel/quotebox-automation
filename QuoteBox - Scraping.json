    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const data = $json.data;\n\nconst quoteBlocks = data.match(/<div class=\"quote\".*?<\\/div>\\s*<\\/div>/gs) || [];\n\nconst results = quoteBlocks.map(block => {\n  const textMatch = block.match(/<span class=\"text\"[^>]*>(.*?)<\\/span>/s);\n  const authorMatch = block.match(/<small class=\"author\"[^>]*>(.*?)<\\/small>/s);\n  const tagMatches = [...block.matchAll(/<a class=\"tag\"[^>]*>(.*?)<\\/a>/gs)];\n\n  const decode = (str) => str\n    .replace(/&#39;/g, \"'\")\n    .replace(/&quot;/g, '\"')\n    .replace(/&amp;/g, \"&\")\n    .trim();\n\n  const text = textMatch ? decode(textMatch[1]).replace(/\\s+/g, ' ') : null;\n  const author = authorMatch ? decode(authorMatch[1]) : null;\n  const tags = tagMatches.map(m => decode(m[1]));\n\n  return { text, author, tags };\n});\n\nreturn { json: { quotes: results } };"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -816,
        -672
      ],
      "id": "6a9a662e-58d2-47e6-a431-de6b5b0ca5e9",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "jsCode": "const loginData = $input.first().json;\nconst cookie = loginData.headers[\"set-cookie\"][0].split(\";\")[0].split(\"=\")[1];\n\nconst items = [];\nfor (let i = 1; i <= 10; i++) {\n  items.push({\n    json: {\n      url: `https://quotes.toscrape.com/page/${i}/`,\n      page: i,\n      cookie: cookie\n    }\n  });\n}\nreturn items;"
      },
