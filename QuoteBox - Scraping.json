    {
      "parameters": {
        "jsCode": "const newQuotes = $('Code in JavaScript1').all().map(item => item.json);\n\nif (newQuotes.length === 0) {\n  return [];\n}\n\nconst grouped = {};\nfor (const quote of newQuotes) {\n  for (const tag of quote.tags) {\n    if (!grouped[tag]) grouped[tag] = [];\n    grouped[tag].push(`\"${quote.text}\" — ${quote.author}`);\n  }\n}\n\nlet html = `<h2>Nuevas frases detectadas: ${newQuotes.length}</h2>`;\nfor (const [tag, quotes] of Object.entries(grouped)) {\n  html += `<h3>#${tag}</h3><ul>`;\n  for (const q of quotes) {\n    html += `<li>${q}</li>`;\n  }\n  html += `</ul>`;\n}\n\nreturn [{ json: { emailBody: html, count: newQuotes.length } }];"
      },
