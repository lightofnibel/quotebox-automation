      "id": "5a83a5ab-77ee-40d8-8a33-e5dfc952dc26",
      "name": "un item x frase"
    },
    {
      "parameters": {
        "jsCode": "// Las 100 frases las recuperamos del nodo \"un item x frase\"\nconst quotes = $('un item x frase').all().map(item => item.json);\n\n// Los tags activos vienen del input actual (Get Rows)\nconst tagsConfig = $input.all().map(item => item.json);\nconst activeTags = tagsConfig\n  .filter(row => row.activo === true || row.activo === 'true' || row.activo === 'TRUE')\n  .map(row => row.tag.toLowerCase());\n\nconst filtered = quotes.filter(quote => {\n  const quoteTags = quote.tags.map(t => t.toLowerCase());\n  return quoteTags.some(tag => activeTags.includes(tag));\n});\n\nreturn filtered.map(q => ({ json: q }));"
      },
